{
  "awsAuthRefresh": "aws sso login --profile YOUR_SSO_PROFILE",
  "env": {
    "ANTHROPIC_CUSTOM_HEADERS": "anthropic-beta:context-1m-2025-08-07",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "arn:aws:bedrock:REGION:ACCOUNT:application-inference-profile/OPUS_PROFILE_ID",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "arn:aws:bedrock:REGION:ACCOUNT:application-inference-profile/SONNET_PROFILE_ID",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "arn:aws:bedrock:REGION:ACCOUNT:application-inference-profile/HAIKU_PROFILE_ID",
    "ANTHROPIC_MODEL": "arn:aws:bedrock:REGION:ACCOUNT:application-inference-profile/SONNET_PROFILE_ID[1m]",
    "AWS_PROFILE": "YOUR_SSO_PROFILE",
    "AWS_REGION": "us-west-2",
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "16384",
    "CLAUDE_CODE_USE_BEDROCK": "1",
    "ENABLE_BACKGROUND_TASKS": "1",
    "ENABLE_TOOL_SEARCH": "true",
    "MAX_THINKING_TOKENS": "8000"
  },
  "permissions": {
    "allow": [
      "Bash(glab:*)",
      "Bash(git checkout:*)",
      "Bash(git worktree:*)",
      "Bash(mkdir:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(env)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(cut:*)",
      "Bash(awk:*)",
      "Bash(rg:*)",
      "Glob(**)",
      "Grep(**)",
      "LS(**)",
      "TodoRead",
      "TodoWrite(**)",
      "Task(**)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git blame:*)",
      "Bash(git branch:*)",
      "Bash(git remote -v:*)",
      "Bash(git config --get:*)",
      "Bash(less:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(tree:*)",
      "Bash(pwd:*)",
      "Bash(wc:*)",
      "Bash(diff:*)",
      "Bash(sed -n:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(basename:*)",
      "Bash(dirname:*)",
      "Bash(realpath:*)",
      "Bash(readlink:*)",
      "Bash(curl:*)",
      "Bash(jq:*)",
      "Bash(pylint:*)",
      "Bash(flake8:*)",
      "Bash(mypy:*)",
      "Bash(eslint:*)",
      "Bash(pytest:*)",
      "Bash(make test:*)",
      "Bash(npm test:*)",
      "Bash(make -n:*)",
      "Bash(man:*)",
      "Bash(pydoc:*)",
      "Bash(which:*)",
      "Bash(type:*)",
      "Bash(echo:*)",
      "Bash(printf:*)",
      "Bash(test:*)",
      "Bash(true:*)",
      "Bash(false:*)",
      "Bash(:* | grep:*)",
      "Bash(:* | jq:*)",
      "Bash(:* | head:*)",
      "Bash(:* | tail:*)",
      "Bash(:* | wc:*)",
      "Bash(:* | sort:*)",
      "Bash(:* | uniq:*)",
      "Bash(git add *)",
      "Bash(git commit -m ' *)",
      "Bash(git commit *)",
      "Bash(git reset *)"
    ],
    "deny": [],
    "additionalDirectories": [
      "/tmp"
    ]
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true
  }
}
