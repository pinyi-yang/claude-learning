# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# --- Option A: Anthropic API (direct) ---
# ANTHROPIC_API_KEY=sk-ant-...

# --- Option B: AWS Bedrock via SSO ---
# AWS_PROFILE=your-sso-profile
# AWS_REGION=us-west-2
# ANTHROPIC_DEFAULT_SONNET_MODEL=arn:aws:bedrock:REGION:ACCOUNT:application-inference-profile/PROFILE_ID
# ANTHROPIC_DEFAULT_OPUS_MODEL=arn:aws:bedrock:REGION:ACCOUNT:application-inference-profile/PROFILE_ID
# ANTHROPIC_DEFAULT_HAIKU_MODEL=arn:aws:bedrock:REGION:ACCOUNT:application-inference-profile/PROFILE_ID

# GITHUB_TOKEN=